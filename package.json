{
  "name": "ai-session-cleaner",
  "version": "0.2.0",
  "description": "Inspect and clean local AI coding agent session data",
  "type": "module",
  "bin": {
    "ai-session-cleaner": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvscarlos/ai-session-cleaner.git"
  },
  "homepage": "https://github.com/cvscarlos/ai-session-cleaner#readme",
  "bugs": {
    "url": "https://github.com/cvscarlos/ai-session-cleaner/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{force:true,recursive:true})\"",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "libsql": "^0.5.29"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^18.19.130",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
